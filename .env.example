# ═══════════════════════════════════════════════════════════
# HandyHub — Environment Variables
# ═══════════════════════════════════════════════════════════
#
# LOCAL DEVELOPMENT (SQLite):
#   Copy this file to .env and use the SQLite defaults below.
#   Run: npm run db:push && npm run db:seed
#
# PRODUCTION (PostgreSQL):
#   Set DATABASE_URL to your PostgreSQL connection string.
#   The app auto-detects the DB type and uses the correct adapter.
# ═══════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────

# Local SQLite
DATABASE_URL="file:./prisma/dev.db"

# Production PostgreSQL
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/handyhub?sslmode=require"

# ── NextAuth ────────────────────────────────────────────────

NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ── App Settings ────────────────────────────────────────────

APP_NAME="HandyHub"
APP_DESCRIPTION="Professional Handyman Services"

# ── Email (optional, for password reset) ────────────────────
# Gmail with an App Password: https://myaccount.google.com/apppasswords
# EMAIL_FROM="you@gmail.com"
# EMAIL_PASSWORD="xxxx xxxx xxxx xxxx"

# ── LeaseSign Integration ────────────────────────────────────
# Secret key that LeaseSign uses to call HandyHub's external API.
# Generate with: openssl rand -hex 32
# Must match HANDYHUB_API_KEY in the LeaseSign .env
HANDYHUB_EXTERNAL_API_KEY="generate-a-random-key-here"
