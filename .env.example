# Database
# For local development, use SQLite:
DATABASE_URL="file:./prisma/dev.db"
# For PostgreSQL (production), use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/handyman_db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: node gen-secret.js
NEXTAUTH_SECRET="generate-with-node-gen-secret.js"

# App Settings
APP_NAME="HandyHub"
APP_DESCRIPTION="Professional Handyman Services"
