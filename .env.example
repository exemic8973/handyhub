# Database — PostgreSQL required in production
# Format: postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/handyhub"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: node gen-secret.js
NEXTAUTH_SECRET="generate-with-node-gen-secret.js"

# App Settings
APP_NAME="HandyHub"
APP_DESCRIPTION="Professional Handyman Services"

# Email — Gmail with an App Password (https://myaccount.google.com/apppasswords)
EMAIL_FROM="you@gmail.com"
EMAIL_PASSWORD="xxxx xxxx xxxx xxxx"
